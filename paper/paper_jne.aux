\citation{zheng2015investigating}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Channel $\times $ frequency band DE feature patterns for alert (PERCLOS $<$\,0.4) versus drowsy (PERCLOS $>$\,0.6) states averaged across 23 subjects. The difference map reveals increased theta/alpha activity in posterior channels and decreased beta/gamma in frontal-temporal regions during drowsiness, consistent with established EEG vigilance correlates~\cite  {olbrich2009eeg, strijkstra2003subjective}.}}{7}{figure.2}\protected@file@percent }
\newlabel{fig:heatmap}{{2}{7}{Channel $\times $ frequency band DE feature patterns for alert (PERCLOS $<$\,0.4) versus drowsy (PERCLOS $>$\,0.6) states averaged across 23 subjects. The difference map reveals increased theta/alpha activity in posterior channels and decreased beta/gamma in frontal-temporal regions during drowsiness, consistent with established EEG vigilance correlates~\cite {olbrich2009eeg, strijkstra2003subjective}}{figure.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces LOSO cross-subject evaluation. FBTS+EOG with 6 temporal channels achieves the strongest result (COR 0.835), dramatically exceeding all single-modality methods. Ridge regression outperforms SVR for single-modality comparisons due to better regularization with pooled training data ($\approx $19,500 samples).}}{7}{table.5}\protected@file@percent }
\newlabel{tab:loso}{{5}{7}{LOSO cross-subject evaluation. FBTS+EOG with 6 temporal channels achieves the strongest result (COR 0.835), dramatically exceeding all single-modality methods. Ridge regression outperforms SVR for single-modality comparisons due to better regularization with pooled training data ($\approx $19,500 samples)}{table.5}{}}
